    import cv2
    import numpy as np
    import pyautogui
    import keyboard
    import time
    import sys
    import csv

    # Safeties
    pyautogui.PAUSE = 0.05
    pyautogui.FAILSAFE = True

    class AsphaltHybridBot:
        def __init__(self, blueprint_path):
            print("Initializing Asphalt Hybrid Engine...")
            self.blueprint_path = blueprint_path
            self.action_queue = []
            self.state = "TASK_MANAGER"
            self.race_start_time = 0
            
            # Define the order of operations your bot should take
            self.daily_tasks = ["VIP", "DAILY_GOALS", "SPONSORSHIP"]
            self.grind_mode = "MP1" # What to do after daily tasks are done
            
            self.load_templates()
            self.load_blueprint()

        def load_templates(self):
            """Load OpenCV templates into memory."""
            # Core UI templates
            self.btn_race = cv2.imread('templates/race_btn.png', 0)
            self.btn_next = cv2.imread('templates/next_btn.png', 0)
            self.ui_racing = cv2.imread('templates/touchdrive_icon.png', 0) # An icon only visible while driving
            self.home = cv2.imread('templates/home_btn.png', 0)
            
            # VIP Task Templates
            self.vip_logo = cv2.imread('templates/vip_logo.png', 0)
            self.vip_logo_tab = cv2.imread('templates/vip_logo_tab.png', 0)
            self.vip_claim_btn = cv2.imread('templates/vip_claim_btn.png', 0)

            if self.btn_race is None or self.ui_racing is None:
                print("CRITICAL ERROR: Missing core template images in 'templates/' folder.")
                sys.exit()
                
            if self.vip_logo is None or self.vip_logo_tab is None or self.vip_claim_btn is None:
                print("WARNING: VIP templates missing. The VIP task may fail.")

        def load_blueprint(self):
            """Loads the track choreography from a CSV file."""
            self.action_queue = []
            try:
                with open(self.blueprint_path, mode='r') as file:
                    reader = csv.DictReader(file)
                    for row in reader:
                        self.action_queue.append({
                            'timestamp': float(row['timestamp']),
                            'action': row['action'].strip().lower(),
                            'duration': float(row['duration']) if row['duration'] else 0.0
                        })
                # Sort by timestamp to ensure chronological execution
                self.action_queue.sort(key=lambda x: x['timestamp'])
                print(f"Loaded {len(self.action_queue)} track instructions.")
            except FileNotFoundError:
                print(f"Error: Could not find track blueprint '{self.blueprint_path}'.")
                sys.exit()

        def scan_screen(self, template, threshold=0.85):
            """Helper function to find an image on the screen and return its center coordinates."""
            if template is None: 
                return None
            
            # Capture screenshot with pyautogui and convert to grayscale for template matching
            screen_gray = cv2.cvtColor(np.array(pyautogui.screenshot()), cv2.COLOR_RGB2GRAY)

            # Using matchTemplate (OpenCV function) to find the location of template in the screenshot
            res = cv2.matchTemplate(screen_gray, template, cv2.TM_CCOEFF_NORMED)
            _, max_val, _, max_loc = cv2.minMaxLoc(res)
            
            if max_val >= threshold:
                h, w = template.shape
                return (max_loc[0] + (w // 2), max_loc[1] + (h // 2))
            return None

        def execute_action(self, action_type, duration):
            """Fires the physical hardware keystrokes."""
            print(f"[{time.strftime('%H:%M:%S')}] Executing: {action_type.upper()}")
            if action_type == "shockwave":
                pyautogui.press('space')
                time.sleep(0.05)
                pyautogui.press('space')
            elif action_type == "360":
                pyautogui.press('s')
                time.sleep(0.05)
                pyautogui.press('s')
            elif action_type == "drift":
                pyautogui.keyDown('s')
                time.sleep(duration)
                pyautogui.keyUp('s')

        # --- NEW: MODULAR TASK FUNCTIONS ---
        def handle_vip_claim(self):
            print("Task: Claiming VIP Points...")
            
            # Step 1: Find coordinates and click the main VIP logo
            vip_loc = self.scan_screen(self.vip_logo)
            if vip_loc:
                print("Found VIP logo. Clicking...")
                pyautogui.click(vip_loc)
                time.sleep(2)
            else:
                print("Could not find VIP logo. Task failed.")
                return True

            # Step 2: Find and click the vip_logo_tab
            tab_loc = self.scan_screen(self.vip_logo_tab)
            if tab_loc:
                print("Found VIP tab. Clicking...")
                pyautogui.click(tab_loc)
                time.sleep(2) 
            else:
                print("Could not find VIP tab. Task failed..")
                return True
                
            # Step 3: Find and click the Claim button
            claim_loc = self.scan_screen(self.vip_claim_btn)
            home_loc = self.scan_screen(self.home)
            if claim_loc:
                print("Found VIP Claim button. Clicking...")
                pyautogui.click(claim_loc)
                time.sleep(3) 
                
                # Press 'Esc' or a back key to return to the main menu
                # You may need to replace this with an OpenCV scan of the game's "Back" arrow
                print("Claimed! Returning to home")
                pyautogui.press('esc') 
                time.sleep(2)
            else:
                print("Claim button not found or already claimed. Returning to menu.")
                pyautogui.press('esc')
                time.sleep(2)

            return True # Return True when the task is completely finished

        def handle_daily_goals(self):
            print("Task: Claiming Daily Goals...")
            # TODO: Add logic to navigate to goals, claim all, and return to main menu
            time.sleep(2)
            return True

        def handle_sponsorship(self):
            print("Task: Handling Sponsorships...")
            # TODO: Add logic to claim sponsorships
            time.sleep(2)
            return True

        def navigate_to_multiplayer(self, mode):
            print(f"Task: Navigating to {mode}...")
            # TODO: Logic to click Multiplayer -> Click MP1/MP2 -> Select Car -> Click Race
            
            # Once the "Race" button is clicked and loading starts:
            self.state = "MENU_RACE_WAITING" 
            return True
        
        def run_daily_task(self):
            self.handle_vip_claim()
            

        def run(self):
            print("Bot active. Press 'q' to kill the script.")
            time.sleep(2)

            while True:
                if keyboard.is_pressed('q'):
                    print("Kill switch activated.")
                    break


                # --- 2. MENU WAITING STATE ---
                elif self.state == "MENU_RACE_WAITING":
                    # We are in the lobby/loading screen, wait for the race UI to appear
                    if self.scan_screen(self.ui_racing, threshold=0.80):
                        print("Race UI detected! Switching to RACING state.")
                        self.state = "RACING"
                        self.race_start_time = time.time()
                        time.sleep(1)

                # --- 3. RACING STATE LOGIC ---
                elif self.state == "RACING":
                    elapsed_time = time.time() - self.race_start_time
                    
                    # Check if we have scheduled commands left in the queue
                    if self.action_queue:
                        next_cmd = self.action_queue[0]
                        
                        # If current time has reached or passed the command's scheduled time
                        if elapsed_time >= next_cmd['timestamp']:
                            # Remove it from the queue and execute it
                            cmd = self.action_queue.pop(0)
                            self.execute_action(cmd['action'], cmd['duration'])
                    
                    # Periodically check if the race ended by looking for the "Next" button
                    # (We only check every ~3 seconds to save CPU during the race)
                    if int(elapsed_time) % 3 == 0:
                        if self.scan_screen(self.btn_next, threshold=0.85):
                            print("Race finished! Returning to Task Manager.")
                            pyautogui.click(self.scan_screen(self.btn_next))
                            time.sleep(3)
                            self.state = "TASK_MANAGER" # Go back to the top brain
                            self.load_blueprint() # Reset track commands

                time.sleep(0.05) # Loop throttle

    if __name__ == "__main__":
        # Point the bot to our track configuration file
        bot = AsphaltHybridBot("cairo_track.csv")
        bot.run()